---
const fallback = {
  isPlaying: false,
  album: null,
  artist: null,
  image: null,
}

let spotify = fallback

try {
  const apiUrl = new URL('/api/spotify', Astro.url)
  const res = await fetch(apiUrl)
  const contentType = res.headers.get('content-type') ?? ''

  if (!res.ok || !contentType.includes('application/json')) {
    throw new Error(`Invalid Spotify API response: ${res.status} ${contentType}`)
  }

  spotify = { ...fallback, ...(await res.json()) }
} catch (error) {
  console.error('Spotify widget fetch error', error)
}

const { isPlaying, album, artist, image } = spotify
---

<div class="spotify-widget">
  <section >
    <div class="header">
      <h1>Spotify</h1>
      <img class="spotify-icon" src="/icons/spotify.svg" alt="spotify-icon">
    </div>
    <div class="spotify-content">
      {image
  ? <img id="spotify-album-image" class="spotify-album" src={image} alt="album-cover">
  : <div id="spotify-album-image" class="spotify-album spotify-album-fallback">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white">
        <path d="M12 3v10.55A4 4 0 1 0 14 17V7h4V3h-6z"/>
      </svg>
    </div>
}
      <div class="spotify-music">
        <p id="spotify-album-text">{isPlaying ? album ?? 'Unknown album' : 'Not playing right now'}</p>
        <p id="spotify-artist-text">{isPlaying ? artist ?? 'Unknown artist' : ''}</p>
      </div>
    </div>
   </section>

</div>

<script is:inline>

  const spotifyFallback = {
    isPlaying: false,
    album: null,
    artist: null,
    image: null,
  }

  const albumTextEl = document.getElementById('spotify-album-text')
  const artistTextEl = document.getElementById('spotify-artist-text')
  const albumImageEl = document.getElementById('spotify-album-image')

  function renderSpotify(data) {
    const spotify = { ...spotifyFallback, ...data }
    const albumText = spotify.isPlaying
      ? (spotify.album ?? 'Unknown album')
      : 'Not playing right now'
    const artistText = spotify.isPlaying
      ? (spotify.artist ?? 'Unknown artist')
      : ''

    if (albumTextEl) albumTextEl.textContent = albumText
    if (artistTextEl) artistTextEl.textContent = artistText

    if (albumImageEl) {
      albumImageEl.src = spotify.image ?? ''
    }
  }

  async function refreshSpotify() {
    try {
      const res = await fetch('/api/spotify', { cache: 'no-store' })
      const contentType = res.headers.get('content-type') ?? ''

      if (!res.ok || !contentType.includes('application/json')) {
        throw new Error(`Invalid Spotify API response: ${res.status} ${contentType}`)
      }

      const data = await res.json()
      renderSpotify(data)
    } catch (error) {
      console.error('Spotify widget interval fetch error', error)
    }
  }

  const spotifyIntervalId = setInterval(refreshSpotify, 10000)

  window.addEventListener('beforeunload', () => {
    clearInterval(spotifyIntervalId)
  })
</script>

<style>
  p{
    margin: 0;
  }

  p:first-child{
    font-size: clamp(1.125rem, 3.2vw, 1.75rem);
    font-weight: bold;
  }

.spotify-widget {
  color: white;
  display: flex;
  flex-direction: column;
  width: 100%;
  border-radius: var(--card-radius);
  background-color: var(--spotify-widget-card);
  padding: clamp(1rem, 4.5vw, 2.6rem);
}

.header{
  display: flex;
  flex-direction: row;
  justify-content: space-between;
}

.spotify-icon{
  width: clamp(2rem, 8vw, 4rem);
}

.spotify-album{
  width: clamp(5.5rem, 24vw, 9rem);
  border-radius: clamp(0.75rem, 2vw, 1.5rem);

}

.spotify-content{
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: clamp(0.75rem, 2.5vw, 1.5rem);
}

.spotify-music{
  display: flex;
  flex-direction: column;
  gap: clamp(0.35rem, 1.4vw, 0.75rem);

}

</style>
