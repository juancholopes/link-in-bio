---
const fallback = {
  isPlaying: false,
  currentlyPlayingType: null,
  timestamp: null,
  progressMs: null,
  track: {
    title: null,
    artist: null,
    album: null,
    durationMs: null,
    id: null,
    uri: null,
    url: null,
  },
  artwork: {
    url: null,
    width: null,
    height: null,
  },
  context: {
    type: null,
    uri: null,
    url: null,
  },
}

let spotify = fallback

const { isPlaying } = spotify
const trackTitle = spotify.track?.title
const trackArtist = spotify.track?.artist
const artworkUrl = spotify.artwork?.url
const artworkWidth = spotify.artwork?.width
---

<div class="spotify-widget">
  <section >
    <div class="header">
      <h1>Spotify</h1>
      <img class="spotify-icon" src="/icons/spotify.svg" alt="spotify-icon">
    </div>
    <div class="spotify-content">
        {artworkUrl
      ? <img id="spotify-album-image" class="spotify-album" src={artworkUrl} width={artworkWidth ?? undefined} alt="album-cover">
  : <div id="spotify-album-image" class="spotify-album spotify-album-fallback">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white">
        <path d="M12 3v10.55A4 4 0 1 0 14 17V7h4V3h-6z"/>
      </svg>
    </div>
}
      <div class="spotify-music">
        <p id="spotify-album-text">{isPlaying ? trackTitle ?? 'Unknown track' : 'Not playing right now'}</p>
        <p id="spotify-artist-text">{isPlaying ? trackArtist ?? 'Unknown artist' : ''}</p>
      </div>
    </div>
   </section>

</div>

<script is:inline>

  const spotifyFallback = {
    isPlaying: false,
    currentlyPlayingType: null,
    timestamp: null,
    progressMs: null,
    track: {
      title: null,
      artist: null,
      album: null,
      durationMs: null,
      id: null,
      uri: null,
      url: null,
    },
    artwork: {
      url: null,
      width: null,
      height: null,
    },
    context: {
      type: null,
      uri: null,
      url: null,
    },
  }

  const albumTextEl = document.getElementById('spotify-album-text')
  const artistTextEl = document.getElementById('spotify-artist-text')

  function getScopeAttrName(el) {
    if (!el) return null
    const scopeAttr = [...el.attributes].find(({ name }) => name.startsWith('data-astro-cid-'))
    return scopeAttr?.name ?? null
  }

  function applyArtworkDimensions(img, artwork) {
    const width = Number(artwork?.width)

    if (Number.isFinite(width) && width > 0) {
      img.width = width
    } else {
      img.removeAttribute('width')
    }
  }

  function createAlbumImageElement(artwork, scopeAttrName) {
    const img = document.createElement('img')
    img.id = 'spotify-album-image'
    img.className = 'spotify-album'
    img.src = artwork.url
    img.alt = 'album-cover'
    applyArtworkDimensions(img, artwork)
    if (scopeAttrName) img.setAttribute(scopeAttrName, '')
    return img
  }

  function createFallbackElement(scopeAttrName) {
    const fallback = document.createElement('div')
    fallback.id = 'spotify-album-image'
    fallback.className = 'spotify-album spotify-album-fallback'
    if (scopeAttrName) fallback.setAttribute(scopeAttrName, '')

    fallback.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white"><path d="M12 3v10.55A4 4 0 1 0 14 17V7h4V3h-6z"/></svg>'
    return fallback
  }

function renderSpotify(data) {
  const spotify = { ...spotifyFallback, ...data }
  const albumImageEl = document.getElementById('spotify-album-image')
  const scopeAttrName = getScopeAttrName(albumImageEl)
  const artwork = spotify.artwork ?? spotifyFallback.artwork
  
  const albumText = spotify.isPlaying ? (spotify.track?.title ?? 'Unknown track') : 'Not playing right now'
  const artistText = spotify.isPlaying ? (spotify.track?.artist ?? 'Unknown artist') : ''

  if (albumTextEl) albumTextEl.textContent = albumText
  if (artistTextEl) artistTextEl.textContent = artistText

  if (albumImageEl) {
    if (artwork?.url) {
      if (albumImageEl.tagName === 'IMG') {
        albumImageEl.src = artwork.url
        applyArtworkDimensions(albumImageEl, artwork)
      } else {
        const img = createAlbumImageElement(artwork, scopeAttrName)
        albumImageEl.replaceWith(img)
      }
    } else if (albumImageEl.tagName === 'IMG') {
      const fallback = createFallbackElement(scopeAttrName)
      albumImageEl.replaceWith(fallback)
    }
  }
}

  async function refreshSpotify() {
    try {
      const res = await fetch('/api/spotify', { cache: 'no-store' })
      const contentType = res.headers.get('content-type') ?? ''

      if (!res.ok || !contentType.includes('application/json')) {
        throw new Error(`Invalid Spotify API response: ${res.status} ${contentType}`)
      }

      const data = await res.json()
      renderSpotify(data)
    } catch (error) {
      console.error('Spotify widget interval fetch error', error)
    }
  }

  refreshSpotify()
  const spotifyIntervalId = setInterval(refreshSpotify, 5000)

  window.addEventListener('beforeunload', () => {
    clearInterval(spotifyIntervalId)
  })
</script>

<style>
  p{
    margin: 0;
  }

  p:first-child{
    font-size: clamp(1.125rem, 3.2vw, 1.75rem);
    font-weight: bold;
  }

.spotify-widget {
  color: white;
  display: flex;
  flex-direction: column;
  width: 100%;
  border-radius: var(--card-radius);
  background-color: var(--spotify-widget-card);
  padding: clamp(1rem, 4.5vw, 2.6rem);
}

.header{
  display: flex;
  flex-direction: row;
  justify-content: space-between;
}

.spotify-icon{
  width: clamp(2rem, 8vw, 4rem);
}

.spotify-album{
  width: clamp(5.5rem, 24vw, 9rem);
  aspect-ratio: 1 / 1;
  object-fit: cover;
  display: block;
  flex-shrink: 0;
  border-radius: clamp(0.75rem, 2vw, 1.5rem);

}

.spotify-album-fallback{
  display: grid;
  place-items: center;
  background-color: rgba(0, 0, 0, 0.18);
}

.spotify-album-fallback svg{
  width: 45%;
  height: 45%;
}

.spotify-content{
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: clamp(0.75rem, 2.5vw, 1.5rem);
}

.spotify-music{
  display: flex;
  flex-direction: column;
  gap: clamp(0.35rem, 1.4vw, 0.75rem);

}

</style>
